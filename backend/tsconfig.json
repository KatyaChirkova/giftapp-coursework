// содержит настройки компиляции TypeScript-кода
{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "incremental": false,
    "strict": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"]
}